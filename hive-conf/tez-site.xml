<?xml version="1.0"?>
<configuration>
  <property>
    <name>tez.lib.uris</name>
    <value>${fs.defaultFS}/apps/tez/tez,${fs.defaultFS}/apps/tez/tez/lib,${fs.defaultFS}/apps/tez/tez/conf</value>
  </property>
  <property>
    <name>tez.use.cluster.hadoop-libs</name>
    <value>true</value>
  </property>
  <property>
    <name>tez.cluster.additional.classpath.prefix</name>
    <value>/opt/hadoop-3.2.1/share/hadoop/mapreduce/*:/opt/hadoop-3.2.1/share/hadoop/mapreduce/lib/*</value>
  </property>
  <property>
    <name>tez.user.classpath.first</name>
    <value>false</value>
  </property>
  <property>
    <name>tez.am.staging-dir</name>
    <value>/tmp/tez</value>
  </property>
  <property>
    <name>tez.am.resource.memory.mb</name>
    <value>256</value>
  </property>
  <property>
    <name>tez.am.launch.cmd-opts</name>
    <value>-Xmx192m</value>
  </property>
  <property>
    <name>tez.task.resource.memory.mb</name>
    <value>256</value>
  </property>
  <property>
    <name>tez.task.launch.cmd-opts</name>
    <value>-Xmx192m</value>
  </property>
</configuration>
